# ==========================================

**/dist/
**/build/
**/.next/
**/coverage/

# ==========================================
# Environment Files
# ==========================================

**/.env
**/.env.local
**/.env.development
**/.env.production
**/.env.test

# Allow examples
!**/.env.example

# ==========================================
# Logs
# ==========================================

**/*.log
**/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# Uploads
# ==========================================

loan-management-system/uploads/*
!loan-management-system/uploads/.gitkeep

# ==========================================
